{
  "expo": {
    "name": "ZoomyPOS",
    "slug": "zoomy-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zoomypos",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.zoomy-pos",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "ZoomyPOS needs camera access to take receipt photos as proof of payment.",
        "NSMicrophoneUsageDescription": "ZoomyPOS does not use the microphone.",
        "NSPhotoLibraryUsageDescription": "ZoomyPOS needs photo library access to upload your GCash QR code and save receipt photos."
      }
    },
    "android": {
      "package": "com.zoomypos.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "cameraPermission": "ZoomyPOS needs camera access to take receipt photos as proof of payment.",
          "microphonePermission": "ZoomyPOS does not use the microphone.",
          "photosPermission": "ZoomyPOS needs photo library access to upload your GCash QR code and save receipt photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ZoomyPOS needs photo library access to save receipt photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5d420805-2236-4266-b2cc-a320076a21c3"
      }
    }
  }
}
